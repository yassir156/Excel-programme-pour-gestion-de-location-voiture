 <Styles>
  <Style ss:ID="Header"><Font ss:Bold="1"/><Interior ss:Color="#D9E1F2" ss:Pattern="Solid"/></Style>
 </Styles>
 <Worksheet ss:Name="PARAMETRES"><Table><Row><Cell s="Header"><Data ss:Type="String">Parametre</Data></Cell><Cell s="Header"><Data ss:Type="String">Valeur</Data></Cell></Row><Row><Cell><Data ss:Type="String">Agence</Data></Cell><Cell><Data ss:Type="String">Sefrou</Data></Cell></Row><Row><Cell><Data ss:Type="String">Devise</Data></Cell><Cell><Data ss:Type="String">DH</Data></Cell></Row><Row><Cell><Data ss:Type="String">Format date</Data></Cell><Cell><Data ss:Type="String">jj/mm/aaaa</Data></Cell></Row><Row><Cell><Data ss:Type="String">Remise auto longue durée %</Data></Cell><Cell><Data ss:Type="String">10</Data></Cell></Row><Row><Cell><Data ss:Type="String">Seuil jours remise auto</Data></Cell><Cell><Data ss:Type="String">30</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="VEHICULES"><Table><Row><Cell s="Header"><Data ss:Type="String">VehiculeID</Data></Cell><Cell s="Header"><Data ss:Type="String">Immatriculation</Data></Cell><Cell s="Header"><Data ss:Type="String">Marque</Data></Cell><Cell s="Header"><Data ss:Type="String">Modele</Data></Cell><Cell s="Header"><Data ss:Type="String">Annee</Data></Cell><Cell s="Header"><Data ss:Type="String">Km</Data></Cell><Cell s="Header"><Data ss:Type="String">Carburant</Data></Cell><Cell s="Header"><Data ss:Type="String">PrixJourDH</Data></Cell><Cell s="Header"><Data ss:Type="String">Statut</Data></Cell><Cell s="Header"><Data ss:Type="String">DateAjout</Data></Cell><Cell s="Header"><Data ss:Type="String">CA_Total_DH</Data></Cell><Cell s="Header"><Data ss:Type="String">Total_Paye_DH</Data></Cell><Cell s="Header"><Data ss:Type="String">Reste_DH</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="CLIENTS"><Table><Row><Cell s="Header"><Data ss:Type="String">ClientID</Data></Cell><Cell s="Header"><Data ss:Type="String">CIN</Data></Cell><Cell s="Header"><Data ss:Type="String">Nom</Data></Cell><Cell s="Header"><Data ss:Type="String">Prenom</Data></Cell><Cell s="Header"><Data ss:Type="String">Telephone</Data></Cell><Cell s="Header"><Data ss:Type="String">Adresse</Data></Cell><Cell s="Header"><Data ss:Type="String">PermisNumero</Data></Cell><Cell s="Header"><Data ss:Type="String">PermisExpiration</Data></Cell><Cell s="Header"><Data ss:Type="String">DateAjout</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="LOCATIONS"><Table><Row><Cell s="Header"><Data ss:Type="String">LocationID</Data></Cell><Cell s="Header"><Data ss:Type="String">NumeroContrat</Data></Cell><Cell s="Header"><Data ss:Type="String">ClientID</Data></Cell><Cell s="Header"><Data ss:Type="String">VehiculeID</Data></Cell><Cell s="Header"><Data ss:Type="String">DateDebut</Data></Cell><Cell s="Header"><Data ss:Type="String">DateFinPrevue</Data></Cell><Cell s="Header"><Data ss:Type="String">DateRetourReelle</Data></Cell><Cell s="Header"><Data ss:Type="String">NbJours</Data></Cell><Cell s="Header"><Data ss:Type="String">PrixJourDH</Data></Cell><Cell s="Header"><Data ss:Type="String">RemisePctManuelle</Data></Cell><Cell s="Header"><Data ss:Type="String">RemisePctAuto</Data></Cell><Cell s="Header"><Data ss:Type="String">RemisePctFinale</Data></Cell><Cell s="Header"><Data ss:Type="String">MontantBrut</Data></Cell><Cell s="Header"><Data ss:Type="String">MontantRemise</Data></Cell><Cell s="Header"><Data ss:Type="String">MontantNet</Data></Cell><Cell s="Header"><Data ss:Type="String">TotalPaye</Data></Cell><Cell s="Header"><Data ss:Type="String">ResteAPayer</Data></Cell><Cell s="Header"><Data ss:Type="String">Statut</Data></Cell><Cell s="Header"><Data ss:Type="String">EtatDepart</Data></Cell><Cell s="Header"><Data ss:Type="String">EtatRetour</Data></Cell><Cell s="Header"><Data ss:Type="String">DateCreation</Data></Cell></Row><Row><Cell><Data ss:Type="String">1</Data></Cell><Cell><Data ss:Type="String">=CONCATENATE("CTR-",TEXT(U2,"yyyymm"),"-",TEXT(A2,"0000"))</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">01/01/2026</Data></Cell><Cell><Data ss:Type="String">05/01/2026</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">=MAX(1,F2-E2)</Data></Cell><Cell><Data ss:Type="String">300</Data></Cell><Cell><Data ss:Type="String">0</Data></Cell><Cell><Data ss:Type="String">=IF(H2&gt;=PARAMETRES!R6C2,PARAMETRES!R5C2,0)</Data></Cell><Cell><Data ss:Type="String">=MAX(J2,K2)</Data></Cell><Cell><Data ss:Type="String">=H2*I2</Data></Cell><Cell><Data ss:Type="String">=M2*L2/100</Data></Cell><Cell><Data ss:Type="String">=M2-N2</Data></Cell><Cell><Data ss:Type="String">=SUMIF(PAIEMENTS!C2,RC1,PAIEMENTS!C5)</Data></Cell><Cell><Data ss:Type="String">=O2-P2</Data></Cell><Cell><Data ss:Type="String">RESERVATION</Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String"></Data></Cell><Cell><Data ss:Type="String">=TODAY()</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="PAIEMENTS"><Table><Row><Cell s="Header"><Data ss:Type="String">PaiementID</Data></Cell><Cell s="Header"><Data ss:Type="String">LocationID</Data></Cell><Cell s="Header"><Data ss:Type="String">DatePaiement</Data></Cell><Cell s="Header"><Data ss:Type="String">ModePaiement</Data></Cell><Cell s="Header"><Data ss:Type="String">MontantDH</Data></Cell><Cell s="Header"><Data ss:Type="String">Reference</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="ENTRETIEN"><Table><Row><Cell s="Header"><Data ss:Type="String">EntretienID</Data></Cell><Cell s="Header"><Data ss:Type="String">VehiculeID</Data></Cell><Cell s="Header"><Data ss:Type="String">Type</Data></Cell><Cell s="Header"><Data ss:Type="String">DateOperation</Data></Cell><Cell s="Header"><Data ss:Type="String">DateProchaine</Data></Cell><Cell s="Header"><Data ss:Type="String">KmOperation</Data></Cell><Cell s="Header"><Data ss:Type="String">CoutDH</Data></Cell><Cell s="Header"><Data ss:Type="String">Notes</Data></Cell><Cell s="Header"><Data ss:Type="String">Alerte</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="RECHERCHE"><Table><Row><Cell s="Header"><Data ss:Type="String">Critere</Data></Cell><Cell s="Header"><Data ss:Type="String">Valeur</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="DASHBOARD"><Table><Row><Cell s="Header"><Data ss:Type="String">Indicateur</Data></Cell><Cell s="Header"><Data ss:Type="String">Valeur</Data></Cell></Row><Row><Cell><Data ss:Type="String">CA total (DH)</Data></Cell><Cell><Data ss:Type="String">=SUM(LOCATIONS!C15)</Data></Cell></Row><Row><Cell><Data ss:Type="String">Total payé (DH)</Data></Cell><Cell><Data ss:Type="String">=SUM(LOCATIONS!C16)</Data></Cell></Row><Row><Cell><Data ss:Type="String">Reste à payer (DH)</Data></Cell><Cell><Data ss:Type="String">=SUM(LOCATIONS!C17)</Data></Cell></Row></Table></Worksheet><Worksheet ss:Name="RAPPORTS"><Table><Row><Cell s="Header"><Data ss:Type="String">TypeRapport</Data></Cell><Cell s="Header"><Data ss:Type="String">Description</Data></Cell></Row></Table></Worksheet>
